# GitHub Personal Access Token (fine-grained, read:user scope)
# Optional but recommended — enables contribution heatmap for all visitors without OAuth
GITHUB_TOKEN=ghp_your_token_here

# GitHub OAuth App — required for "Sign in with GitHub" feature
# Create at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# NextAuth
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
